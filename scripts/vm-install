#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname -- "${BASH_SOURCE[0]}")/.."

export NOTARCHY_KEYBOARD_LAYOUT=br
export NOTARCHY_KEYBOARD_VARIANT=abnt2
export NOTARCHY_LOCATION=Juazeiro

password_file=/tmp/notarchy-vm-password
umask 077
printf 'notarchy\n' > "$password_file"
trap 'rm -f "$password_file"' EXIT

./install/notarchy-install \
  --disk /dev/vda \
  --hostname notarchy \
  --username notliad \
  --disk-password-file "$password_file" \
  --user-password-file "$password_file" \
  --profile notarchy \
  --yes
