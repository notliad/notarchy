#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
tmp="$(mktemp -d)"
trap 'rm -rf "$tmp"' EXIT
printf 'notarchy\n' > "$tmp/password"

install_dry_run() {
  local profile="$1"
  shift
  NOTARCHY_NO_GUM=1 "$repo_root/install/notarchy-install" \
    --dry-run \
    --disk /dev/vda \
    --hostname notarchy \
    --username notliad \
    --disk-password-file "$tmp/password" \
    --user-password-file "$tmp/password" \
    --profile "$profile" \
    --yes \
    "$@"
}

output="$(install_dry_run essential)"

required=(
  "Selected disk: /dev/vda"
  "Software: essential"
  "+ pacstrap -K /mnt"
  "+ install -Dm0644 /etc/resolv.conf /mnt/etc/resolv.conf"
  "+ arch-chroot /mnt getent hosts aur.archlinux.org"
  "+ arch-chroot /mnt mkinitcpio -P"
  "+ arch-chroot /mnt bootctl install"
  "+ cp -f /mnt/boot/EFI/systemd/systemd-bootx64.efi /mnt/boot/EFI/BOOT/BOOTX64.EFI"
  "+ chmod 0755 /mnt /mnt/etc"
  "+ arch-chroot /mnt ln -sf /home/notliad/.local/share/notarchy/bin/notarchy-apply /usr/local/bin/notarchy-apply"
  "+ arch-chroot /mnt sudo -u notliad /home/notliad/.local/share/notarchy/bin/notarchy-apply"
)

for needle in "${required[@]}"; do
  if ! grep -Fq "$needle" <<<"$output"; then
    printf 'Missing expected dry-run output: %s\n\n%s\n' "$needle" "$output" >&2
    exit 1
  fi
done

! grep -Fq 'systemctl enable docker.socket' <<<"$output"
! grep -Fq 'usermod -aG docker' <<<"$output"

notarchy_output="$(install_dry_run notarchy)"
grep -Fq 'Software: notarchy (84 official, 20 AUR)' <<<"$notarchy_output"
grep -Fq 'systemctl enable docker.socket' <<<"$notarchy_output"
grep -Fq 'ensure_user_dns' "$repo_root/install/notarchy-install"
grep -Fq 'getent hosts aur.archlinux.org' "$repo_root/install/notarchy-install"
grep -Fq 'env HOME="/home/$username" GIT_CONFIG_NOSYSTEM=1 bash -c' "$repo_root/install/notarchy-install"
! grep -Fq 'sudo -u "$username" bash -lc' "$repo_root/install/notarchy-install"

custom_output="$(install_dry_run custom --programs chrome,docker)"
grep -Fq 'Software: custom' <<<"$custom_output"
grep -Fq 'docker-compose' <<<"$custom_output"
grep -Fq 'systemctl enable docker.socket' <<<"$custom_output"

printf '%s\n' "$output"
printf '\nnotarchy installer dry-run passed\n'
