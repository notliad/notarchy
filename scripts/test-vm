#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
vm_dir="$repo_root/.notarchy/vm"
share_dir="$vm_dir/share"
disk="$vm_dir/disk.qcow2"
vars="$vm_dir/OVMF_VARS.fd"
ovmf_code="${OVMF_CODE:-/usr/share/edk2/x64/OVMF_CODE.4m.fd}"
ovmf_vars="${OVMF_VARS:-/usr/share/edk2/x64/OVMF_VARS.4m.fd}"
arch_iso="${ARCH_ISO:-}"
reset=false
no_iso=false

usage() {
  printf 'Usage: %s [--reset] [--no-iso]\n' "${0##*/}"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --reset) reset=true; shift ;;
    --no-iso) no_iso=true; shift ;;
    -h|--help) usage; exit 0 ;;
    *) usage >&2; exit 2 ;;
  esac
done

if ! "$no_iso" && [[ -z "$arch_iso" ]]; then
  arch_iso="$(find "$HOME/Downloads" -maxdepth 1 -type f -name 'archlinux-*.iso' | sort | tail -n 1)"
fi

"$no_iso" || [[ -f "$arch_iso" ]] || { printf 'Arch ISO not found. Set ARCH_ISO=/path/to/archlinux.iso or use --no-iso\n' >&2; exit 1; }
[[ -f "$ovmf_code" ]] || { printf 'OVMF code not found: %s\n' "$ovmf_code" >&2; exit 1; }
[[ -f "$ovmf_vars" ]] || { printf 'OVMF vars not found: %s\n' "$ovmf_vars" >&2; exit 1; }

mkdir -p "$vm_dir"
mkdir -p "$share_dir"
rsync -a --delete --exclude .git --exclude .notarchy "$repo_root/" "$share_dir/"

if "$reset" || [[ ! -f "$disk" ]]; then
  rm -f "$disk" "$vars"
  qemu-img create -f qcow2 "$disk" 30G >/dev/null
fi
[[ -f "$vars" ]] || cp "$ovmf_vars" "$vars"

if ! "$no_iso"; then
  cat <<EOF
Inside the Arch ISO, run:

mkdir -p /tmp/notarchy && mount -t 9p -o trans=virtio,version=9p2000.L notarchy /tmp/notarchy 2>/dev/null || true
/tmp/notarchy/scripts/vm-install

EOF
fi

qemu_args=(
  -enable-kvm
  -m 4096
  -cpu host
  -smp 4
  -drive "if=pflash,format=raw,readonly=on,file=$ovmf_code"
  -drive "if=pflash,format=raw,file=$vars"
  -drive "file=$disk,format=qcow2,if=virtio"
)

if ! "$no_iso"; then
  qemu_args+=(-cdrom "$arch_iso" -boot d)
fi

qemu_args+=(
  -virtfs "local,path=$share_dir,mount_tag=notarchy,security_model=mapped-xattr"
  -netdev user,id=net0
  -device virtio-net-pci,netdev=net0
  -device virtio-vga
  -display gtk
)

exec qemu-system-x86_64 "${qemu_args[@]}"
