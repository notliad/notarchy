#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
logo="$repo_root/assets/logo.txt"

if [[ ! -f "$logo" ]]; then
  logo="$(mktemp)"
  cat > "$logo" <<'LOGO'
 ⢀⣀⣀⣀⡀     ⣀⣀⣀⣀                    ⢀⣀⣀⣀⣀⣀                    ⢀⣀⣀
 ⢸⣿⣿⣿⣧⣤    ⣿⣿⣿⣿           ⣤⣤⣤     ⣤⣼⣿⣿⣿⣿⣿⣤⡄                  ⢸⣿⣿
 ⢸⣿⣿⣿⣿⣿⣿⣇⡀ ⣿⣿⣿⣿   ⣀⣀⣀⣀  ⢀⣀⣿⣿⣟⣀⣀⡀ ⣿⣿⣿⣿  ⢸⣿⣿⣿⡗ ⣀⣀⣀⣀⣀⡀   ⢀⣀⣀⣀⣀⣀ ⢸⣿⣿⣀⣀⣀  ⢀⣀⣀⡀ ⣀⣀⡀
 ⢸⣿⣿⣿⡟⠛⣿⣿⣷⣴⣿⣿⣿⣿ ⢠⣶⣿⣿⣿⣿⣶⡄⠈⠛⣿⣿⣿⠛⠛⠃ ⣿⣿⣿⣿  ⢸⣿⣿⣿⣿ ⣿⣿⣿⣿⣿⣷⣦ ⢰⣼⣿⣿⣿⣿⣿ ⢸⣿⣿⣿⣿⣿⣴⡄⢸⣿⣿⡇⢸⣿⣿⡇
 ⢸⣿⣿⣿⡇  ⠸⢿⣿⣿⣿⣿⣿ ⢸⣿⣿⡇⢸⣿⣿⡇  ⣿⣿⣷    ⣿⣿⣿⣿⠶⠶⢾⣿⣿⣿⣷ ⣿⣿⣿ ⠿⠿⠿ ⢸⣿⣿     ⢸⣿⣿⠁⢸⣿⣿⡆⢸⣿⣿⣇⣰⣿⣿⡇
 ⢸⣿⣿⣿⡇   ⠈⠛⣿⣿⣿⣿ ⢸⣿⣿⣧⣼⣿⣿⡇  ⣿⣿⣯    ⣿⣿⣿⣿  ⢸⣿⣿⣿⣯ ⣿⣿⣿     ⢸⣿⣿⣤⣤⣤⣤ ⢸⣿⣿ ⢸⣿⣿⡅⠘⠛⣿⣿⣿⣿⣿⡇
 ⠸⠿⠿⠿⠇     ⠿⠿⠿⠿   ⠿⠿⠿⠿    ⠿⠿⠿    ⠿⠿⠿⠿  ⠸⠿⠿⠿⠟ ⠿⠿⠿      ⠸⠿⠿⠿⠿⠿ ⠸⠿⠿ ⠸⠿⠿⠇   ⢹⣿⣿
                                                                        ⢸⣿⣿
                                                                     ⠰⠶⠶⠿⠏
LOGO
fi

screensaver_in_focus() {
  hyprctl activewindow -j | jq -e '.class == "org.notarchy.screensaver"' >/dev/null 2>&1
}

exit_screensaver() {
  hyprctl keyword cursor:invisible false >/dev/null 2>&1 || true
  pkill -x tte 2>/dev/null || true
  pkill -f org.notarchy.screensaver 2>/dev/null || true
  exit 0
}

trap exit_screensaver SIGINT SIGTERM SIGHUP SIGQUIT

printf '\033]11;rgb:00/00/00\007'
hyprctl keyword cursor:invisible true >/dev/null 2>&1 || true
tty_name="$(tty 2>/dev/null || true)"

while true; do
  tte -i "$logo" \
    --frame-rate 120 --canvas-width 0 --canvas-height 0 --reuse-canvas \
    --anchor-canvas c --anchor-text c --random-effect --no-eol --no-restore-cursor &

  while pgrep -t "${tty_name#/dev/}" -x tte >/dev/null 2>&1; do
    if read -r -n1 -t 1 || ! screensaver_in_focus; then
      exit_screensaver
    fi
  done
done
