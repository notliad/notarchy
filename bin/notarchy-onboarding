#!/usr/bin/env bash
set -euo pipefail

config_root="${XDG_CONFIG_HOME:-$HOME/.config}"
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
theme_cmd="${NOTARCHY_WAYBAR_THEME_CMD:-$script_dir/notarchy-waybar-theme}"
notarchy_dir="$config_root/notarchy"
user_env="$notarchy_dir/user.env"
hypr_user="$notarchy_dir/hypr-user.conf"
waybar_style="$notarchy_dir/waybar-style.css"
waybar_config="$notarchy_dir/waybar-config.jsonc"
seen_file="$notarchy_dir/onboarding-seen"
skip_apply="${NOTARCHY_ONBOARDING_SKIP_APPLY:-0}"
first_run=false
[[ "${1:-}" == "--first-run" ]] && first_run=true

all_modules=(
  hyprland/workspaces
  custom/scratchpad
  mpris
  clock
  clock#2
  custom/weather
  cpu
  memory
  tray
  bluetooth
  network
  pulseaudio
  battery
)

default_modules="hyprland/workspaces,custom/scratchpad,mpris,clock,clock#2,custom/weather,cpu,memory,tray,bluetooth,network,pulseaudio,battery"

module_label() {
  case "$1" in
    hyprland/workspaces) printf 'Workspaces' ;;
    custom/scratchpad) printf 'Scratchpad' ;;
    mpris) printf 'Media' ;;
    clock) printf 'Date' ;;
    clock#2) printf 'Time' ;;
    custom/weather) printf 'Weather' ;;
    cpu) printf 'CPU' ;;
    memory) printf 'Memory' ;;
    tray) printf 'Tray' ;;
    bluetooth) printf 'Bluetooth' ;;
    network) printf 'Network' ;;
    pulseaudio) printf 'Audio' ;;
    battery) printf 'Battery' ;;
  esac
}

module_description() {
  case "$1" in
    hyprland/workspaces) printf 'Hyprland workspace dots' ;;
    custom/scratchpad) printf 'Scratchpad workspace toggle' ;;
    mpris) printf 'Current media title and controls' ;;
    clock) printf 'Localized date and calendar' ;;
    clock#2) printf 'Current time' ;;
    custom/weather) printf 'Temperature and forecast tooltip' ;;
    cpu) printf 'CPU usage' ;;
    memory) printf 'Memory usage' ;;
    tray) printf 'System tray icons' ;;
    bluetooth) printf 'Bluetooth status and devices' ;;
    network) printf 'Wi-Fi/Ethernet status' ;;
    pulseaudio) printf 'Volume status and mixer shortcut' ;;
    battery) printf 'Battery status and power menu' ;;
  esac
}

mkdir -p "$notarchy_dir"
[[ -f "$user_env" ]] && source "$user_env"

theme="${NOTARCHY_WAYBAR_THEME:-silver}"
background="${NOTARCHY_WAYBAR_BACKGROUND:-#c7c7c7}"
foreground="${NOTARCHY_WAYBAR_FOREGROUND:-#272838}"
modules="${NOTARCHY_WAYBAR_MODULES:-$default_modules}"
modules="${modules//custom\/mpris/mpris}"
keyboard_layout="${NOTARCHY_KEYBOARD_LAYOUT:-br}"
keyboard_variant="${NOTARCHY_KEYBOARD_VARIANT:-abnt2}"
weather_location="${NOTARCHY_LOCATION:-}"
timezone="${NOTARCHY_TIMEZONE:-$(timedatectl show -p Timezone --value 2>/dev/null || true)}"

have_gum() {
  [[ ${NOTARCHY_NO_GUM:-0} != 1 ]] && command -v gum >/dev/null 2>&1
}

have_zenity() {
  [[ ${NOTARCHY_NO_ZENITY:-0} != 1 ]] && command -v zenity >/dev/null 2>&1 && [[ -n "${WAYLAND_DISPLAY:-}${DISPLAY:-}" ]]
}

ask() {
  local prompt="$1" default="$2" override="${3:-}" answer
  if [[ -n "$override" && -v "$override" ]]; then
    printf '%s\n' "${!override}"
    return
  fi
  if have_zenity; then
    zenity --entry --title "NotArchy Setup" --text "$prompt" --entry-text "$default"
    return
  fi
  if have_gum; then
    gum input --prompt "$prompt " --value "$default"
  else
    read -r -p "$prompt [$default]: " answer
    printf '%s\n' "${answer:-$default}"
  fi
}

ask_color() {
  local prompt="$1" default="$2" override="${3:-}" answer
  if [[ -n "$override" && -v "$override" ]]; then
    printf '%s\n' "${!override}"
    return
  fi
  if have_zenity; then
    answer="$(zenity --color-selection --title "$prompt" --color "$default" --show-palette)"
    normalize_color "$answer"
    return
  fi
  ask "$prompt" "$default"
}

pick_theme() {
  local selected choices=()
  if [[ -n ${NOTARCHY_ONBOARDING_THEME+x} ]]; then
    printf '%s\n' "$NOTARCHY_ONBOARDING_THEME"
    return
  fi
  if have_zenity; then
    mapfile -t choices < <("$theme_cmd" list)
    zenity --list --title "NotArchy Setup" --text "Step 2 of 3 - Waybar theme" --column Theme "${choices[@]}"
    return
  fi
  if have_gum; then
    "$theme_cmd" list | gum choose --selected "$theme" --header "Step 2 of 3 - Waybar theme"
    return
  fi
  printf 'Step 2 of 3 - Waybar theme [%s]: ' "$theme"
  read -r selected
  printf '%s\n' "${selected:-$theme}"
}

write_waybar_style() {
  if [[ "$theme" == custom ]]; then
    {
      printf '@define-color background %s;\n' "$background"
      printf '@define-color foreground %s;\n' "$foreground"
      printf '@define-color accent #427aa1;\n'
      printf '@define-color muted #786f52;\n'
      printf '@define-color critical #cc2936;\n'
    } > "$waybar_style"
  else
    "$theme_cmd" css "$theme" > "$waybar_style"
  fi
}

normalize_color() {
  local color="$1" r g b rgb_re
  if [[ "$color" =~ ^#[0-9A-Fa-f]{6}$ ]]; then
    printf '%s\n' "$color"
    return
  fi
  rgb_re='^rgba?\(([0-9]+),[[:space:]]*([0-9]+),[[:space:]]*([0-9]+)(,[^)]+)?\)$'
  if [[ "$color" =~ $rgb_re ]]; then
    r="${BASH_REMATCH[1]}"
    g="${BASH_REMATCH[2]}"
    b="${BASH_REMATCH[3]}"
    (( r > 255 )) && r=$((r / 257))
    (( g > 255 )) && g=$((g / 257))
    (( b > 255 )) && b=$((b / 257))
    printf '#%02x%02x%02x\n' "$r" "$g" "$b"
    return
  fi
  printf '%s\n' "$color"
}

contains_module() {
  [[ ",$modules," == *",$1,"* ]]
}

valid_hex() {
  [[ "$1" =~ ^#[0-9A-Fa-f]{6}$ ]]
}

valid_modules() {
  local item known module
  local -a picked
  IFS=',' read -ra picked <<<"$modules"
  for item in "${picked[@]}"; do
    known=false
    for module in "${all_modules[@]}"; do
      [[ "$item" == "$module" ]] && known=true
    done
    "$known" || return 1
  done
}

pick_modules() {
  local module selected picked=() args=()
  if [[ -n ${NOTARCHY_ONBOARDING_MODULES+x} ]]; then
    printf '%s\n' "$NOTARCHY_ONBOARDING_MODULES"
    return
  fi
  if have_zenity; then
    for module in "${all_modules[@]}"; do
      if contains_module "$module"; then
        args+=(TRUE "$module" "$(module_label "$module")" "$(module_description "$module")")
      else
        args+=(FALSE "$module" "$(module_label "$module")" "$(module_description "$module")")
      fi
    done
    zenity --list --checklist --multiple --separator=, --print-column=2 \
      --title "NotArchy Setup" \
      --text "Step 3 of 3 - Choose Waybar modules" \
      --column "Use" --column "Module" --column "Name" --column "Description" \
      "${args[@]}"
    return
  fi
  if have_gum; then
    selected="$(printf '%s\n' "${all_modules[@]}" | gum choose --no-limit --ordered --selected "$modules" --header "Step 3 of 3 - Waybar modules")"
    printf '%s\n' "${selected//$'\n'/,}"
    return
  fi
  for module in "${all_modules[@]}"; do
    if contains_module "$module"; then
      picked+=("$module")
    fi
  done
  printf 'Step 3 of 3 - Waybar modules, comma-separated [%s]: ' "$(join_by , "${picked[@]}")"
  read -r selected
  printf '%s\n' "${selected:-$(join_by , "${picked[@]}")}"
}

join_by() {
  local IFS="$1"
  shift
  printf '%s' "$*"
}

json_array() {
  local sep="" item
  printf '['
  for item in "$@"; do
    printf '%s"%s"' "$sep" "$item"
    sep=", "
  done
  printf ']'
}

selected_group() {
  local item result=()
  for item in "$@"; do
    contains_module "$item" && result+=("$item")
  done
  json_array "${result[@]}"
}

write_preferences() {
  [[ "$theme" == custom ]] || read -r background foreground _ < <("$theme_cmd" colors "$theme")
  cat > "$user_env" <<ENV
NOTARCHY_LOCATION=$(printf '%q' "$weather_location")
NOTARCHY_KEYBOARD_LAYOUT=$(printf '%q' "$keyboard_layout")
NOTARCHY_KEYBOARD_VARIANT=$(printf '%q' "$keyboard_variant")
NOTARCHY_TIMEZONE=$(printf '%q' "$timezone")
NOTARCHY_WAYBAR_THEME=$(printf '%q' "$theme")
NOTARCHY_WAYBAR_BACKGROUND=$(printf '%q' "$background")
NOTARCHY_WAYBAR_FOREGROUND=$(printf '%q' "$foreground")
NOTARCHY_WAYBAR_MODULES=$(printf '%q' "$modules")
ENV

  {
    printf 'input {\n'
    printf '  kb_layout = %s\n' "$keyboard_layout"
    [[ -n "$keyboard_variant" ]] && printf '  kb_variant = %s\n' "$keyboard_variant"
    printf '}\n'
  } > "$hypr_user"

  write_waybar_style
}

write_waybar_config() {
  local left=() center=() right=() clock_modules perf_modules right_modules

  contains_module hyprland/workspaces && left+=("group/left-modules")
  contains_module custom/scratchpad && left+=("custom/scratchpad")
  contains_module mpris && left+=("mpris")

  clock_modules="$(selected_group clock clock#2 custom/weather)"
  [[ "$clock_modules" != "[]" ]] && center+=("group/clock-weather" "custom/spacer")

  perf_modules="$(selected_group cpu memory)"
  [[ "$perf_modules" != "[]" ]] && right+=("group/perf-monitor")
  right_modules="$(selected_group tray bluetooth network pulseaudio)"
  [[ "$right_modules" != "[]" ]] && right+=("group/right-modules")
  contains_module battery && right+=("battery")

  cat > "$waybar_config" <<WAYBAR
{
  "include": "../waybar/default-config.jsonc",
  "modules-left": $(json_array "${left[@]}"),
  "modules-center": $(json_array "${center[@]}"),
  "modules-right": $(json_array "${right[@]}"),
  "group/clock-weather": {
    "orientation": "inherit",
    "modules": $clock_modules,
  },
  "group/perf-monitor": {
    "orientation": "inherit",
    "modules": $perf_modules,
  },
  "group/left-modules": {
    "orientation": "inherit",
    "modules": $(selected_group hyprland/workspaces),
  },
  "group/right-modules": {
    "orientation": "inherit",
    "modules": $right_modules,
  },
}
WAYBAR
}

apply_preferences() {
  [[ "$skip_apply" == 1 ]] && return
  if [[ -n "$timezone" ]]; then
    if command -v pkexec >/dev/null 2>&1; then
      pkexec timedatectl set-timezone "$timezone"
    else
      sudo timedatectl set-timezone "$timezone"
    fi
  fi
  command -v hyprctl >/dev/null 2>&1 && hyprctl reload || true
  command -v waybar >/dev/null 2>&1 || return
  pkill -SIGUSR2 waybar 2>/dev/null && return
  if command -v uwsm-app >/dev/null 2>&1; then
    uwsm-app -- waybar >/dev/null 2>&1 &
  else
    waybar >/dev/null 2>&1 &
  fi
}

ask_system_fields() {
  timezone="$(ask "Step 1 of 3 - Timezone" "$timezone" NOTARCHY_ONBOARDING_TIMEZONE)"
}

welcome() {
  local action="${NOTARCHY_ONBOARDING_ACTION:-}"
  if [[ -z "$action" ]]; then
    if have_zenity; then
      action="$(zenity --list --title 'Welcome to NotArchy' \
        --text 'Personalize your timezone, Waybar appearance, and modules. You can run this again from the NotArchy menu.' \
        --column 'Choose' 'Personalize (3 steps)' 'Use defaults and skip')"
    elif have_gum; then
      action="$(printf '%s\n' 'Personalize (3 steps)' 'Use defaults and skip' | gum choose --header 'Welcome to NotArchy')"
    else
      printf 'Welcome to NotArchy. Personalize timezone and Waybar now? [Y/n]: '
      read -r action
      [[ ! "$action" =~ ^[Nn] ]] && action=personalize
    fi
  fi

  case "$action" in
    personalize|Personalize*) ;;
    *defaults*|*Defaults*|skip|Skip*|"")
      : > "$seen_file"
      printf 'Using NotArchy defaults. Run notarchy-onboarding to personalize later.\n'
      exit 0
      ;;
    *) printf 'Invalid onboarding action: %s\n' "$action" >&2; exit 2 ;;
  esac
}

if [[ "${1:-}" == "--ensure-defaults" ]]; then
  [[ -f "$user_env" && -f "$hypr_user" && -f "$waybar_style" ]] || write_preferences
  [[ -f "$waybar_config" ]] || write_waybar_config
  exit 0
fi

"$first_run" && welcome

ask_system_fields
theme="$(pick_theme)"
modules="$(pick_modules)"

if [[ -n ${NOTARCHY_ONBOARDING_BACKGROUND+x} || -n ${NOTARCHY_ONBOARDING_FOREGROUND+x} ]]; then
  background="$(ask_color "Step 2 of 3 - Waybar background" "$background" NOTARCHY_ONBOARDING_BACKGROUND)"
  foreground="$(ask_color "Step 2 of 3 - Waybar foreground" "$foreground" NOTARCHY_ONBOARDING_FOREGROUND)"
  theme=custom
fi

if [[ "$theme" == custom ]]; then
  valid_hex "$background" || { printf 'Invalid background color: %s\n' "$background" >&2; exit 1; }
  valid_hex "$foreground" || { printf 'Invalid foreground color: %s\n' "$foreground" >&2; exit 1; }
else
  "$theme_cmd" colors "$theme" >/dev/null || { printf 'Invalid Waybar theme: %s\n' "$theme" >&2; exit 1; }
fi

valid_modules || { printf 'Invalid Waybar module list: %s\n' "$modules" >&2; exit 1; }
[[ "$keyboard_layout" =~ ^[A-Za-z0-9_,+-]+$ ]] || { printf 'Invalid keyboard layout: %s\n' "$keyboard_layout" >&2; exit 1; }
[[ "$keyboard_variant" =~ ^[A-Za-z0-9_,+-]*$ ]] || { printf 'Invalid keyboard variant: %s\n' "$keyboard_variant" >&2; exit 1; }
[[ ! "$weather_location" =~ [[:cntrl:]] ]] || { printf 'Invalid weather location.\n' >&2; exit 1; }

if contains_module custom/weather; then
  weather_location="$(ask "Step 3 of 3 - Weather location" "$weather_location" NOTARCHY_ONBOARDING_LOCATION)"
else
  weather_location=""
fi
[[ ! "$weather_location" =~ [[:cntrl:]] ]] || { printf 'Invalid weather location.\n' >&2; exit 1; }

write_preferences
write_waybar_config
apply_preferences
: > "$seen_file"

if have_zenity; then
  zenity --info --title "NotArchy Setup" --text "Setup saved."
fi
printf 'NotArchy onboarding saved.\n'
