#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
config_root="${NOTARCHY_CONFIG_ROOT:-$repo_root/config}"
target_root="${NOTARCHY_TARGET_CONFIG_ROOT:-${XDG_CONFIG_HOME:-$HOME/.config}}"
home_root="${NOTARCHY_HOME_ROOT:-$repo_root/home}"
target_home="${NOTARCHY_TARGET_HOME:-$HOME}"
timestamp="${NOTARCHY_BACKUP_TIMESTAMP:-$(date +%s)}"

usage() {
  printf 'Usage: %s [--dry-run]\n' "${0##*/}"
}

dry_run=false
case "${1:-}" in
  --dry-run) dry_run=true ;;
  -h|--help) usage; exit 0 ;;
  "") ;;
  *) usage >&2; exit 2 ;;
esac

run() {
  if "$dry_run"; then
    printf '+ %q' "$1"
    shift
    for arg in "$@"; do
      printf ' %q' "$arg"
    done
    printf '\n'
  else
    "$@"
  fi
}

ensure_local_preferences() {
  local local_dir="$target_root/notarchy"

  if "$dry_run"; then
    printf '+ ensure local preferences under %q\n' "$local_dir"
    return
  fi

  mkdir -p "$local_dir"
  [[ -e "$local_dir/user.env" ]] || {
    printf 'NOTARCHY_LOCATION=\n'
    printf 'NOTARCHY_KEYBOARD_LAYOUT=br\n'
    printf 'NOTARCHY_KEYBOARD_VARIANT=abnt2\n'
    printf 'NOTARCHY_TIMEZONE=UTC\n'
    printf 'NOTARCHY_WAYBAR_BACKGROUND=#c7c7c7\n'
    printf 'NOTARCHY_WAYBAR_FOREGROUND=#131313\n'
    printf 'NOTARCHY_WAYBAR_MODULES=hyprland/workspaces,custom/scratchpad,mpris,clock,clock#2,custom/weather,cpu,memory,tray,bluetooth,network,pulseaudio,battery\n'
  } > "$local_dir/user.env"
  grep -q '^NOTARCHY_TIMEZONE=' "$local_dir/user.env" || printf 'NOTARCHY_TIMEZONE=UTC\n' >> "$local_dir/user.env"
  grep -q '^NOTARCHY_WAYBAR_BACKGROUND=' "$local_dir/user.env" || printf 'NOTARCHY_WAYBAR_BACKGROUND=#c7c7c7\n' >> "$local_dir/user.env"
  grep -q '^NOTARCHY_WAYBAR_FOREGROUND=' "$local_dir/user.env" || printf 'NOTARCHY_WAYBAR_FOREGROUND=#131313\n' >> "$local_dir/user.env"
  grep -q '^NOTARCHY_WAYBAR_MODULES=' "$local_dir/user.env" || printf 'NOTARCHY_WAYBAR_MODULES=hyprland/workspaces,custom/scratchpad,mpris,clock,clock#2,custom/weather,cpu,memory,tray,bluetooth,network,pulseaudio,battery\n' >> "$local_dir/user.env"
  if grep -q 'custom/mpris' "$local_dir/user.env"; then
    run sed -i 's#custom/mpris#mpris#g' "$local_dir/user.env"
  fi
  [[ -e "$local_dir/hypr-user.conf" ]] || {
    printf 'input {\n'
    printf '  kb_layout = br\n'
    printf '  kb_variant = abnt2\n'
    printf '}\n'
  } > "$local_dir/hypr-user.conf"
  [[ -e "$local_dir/waybar-style.css" ]] || {
    printf '@define-color background #c7c7c7;\n'
    printf '@define-color foreground #131313;\n'
  } > "$local_dir/waybar-style.css"
  [[ -e "$local_dir/waybar-config.jsonc" ]] || {
    cat > "$local_dir/waybar-config.jsonc" <<'WAYBAR'
{
  "include": "../waybar/default-config.jsonc",
  "modules-left": ["group/left-modules", "custom/scratchpad", "mpris"],
  "modules-center": ["group/clock-weather", "custom/spacer"],
  "modules-right": ["group/perf-monitor", "group/right-modules", "battery"],
  "group/clock-weather": {
    "orientation": "inherit",
    "modules": ["clock", "clock#2", "custom/weather"],
  },
  "group/perf-monitor": {
    "orientation": "inherit",
    "modules": ["cpu", "memory"],
  },
  "group/left-modules": {
    "orientation": "inherit",
    "modules": ["hyprland/workspaces"],
  },
  "group/right-modules": {
    "orientation": "inherit",
    "modules": ["tray", "bluetooth", "network", "pulseaudio"],
  },
}
WAYBAR
  }
  if grep -q 'custom/mpris' "$local_dir/waybar-config.jsonc"; then
    run sed -i 's#custom/mpris#mpris#g' "$local_dir/waybar-config.jsonc"
  fi
}

apply_tree() {
  local source_root="$1" target_base="$2"
  [[ -d "$source_root" ]] || return 0

  find "$source_root" -type f -print0 | while IFS= read -r -d '' source; do
    rel="${source#"$source_root"/}"
    target="$target_base/$rel"
    run mkdir -p "$(dirname -- "$target")"

    if [[ -e "$target" || -L "$target" ]]; then
      [[ -f "$target" && ! -L "$target" ]] && cmp -s -- "$source" "$target" && continue
      run mv -- "$target" "$target.bak.$timestamp"
    fi

    run cp -a -- "$source" "$target"
  done
}

[[ -d "$config_root" ]] || {
  printf 'notarchy-apply: config directory not found: %s\n' "$config_root" >&2
  exit 1
}

ensure_local_preferences
apply_tree "$config_root" "$target_root"
apply_tree "$home_root" "$target_home"
