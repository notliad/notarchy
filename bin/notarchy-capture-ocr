#!/usr/bin/env bash
set -euo pipefail

pkill slurp >/dev/null 2>&1 && exit 0

cleanup() {
  [[ -n ${freeze_pid:-} ]] && kill "$freeze_pid" 2>/dev/null || true
}
trap cleanup EXIT

hyprpicker -r -z >/dev/null 2>&1 &
freeze_pid=$!
sleep .1
selection="$(slurp 2>/dev/null || true)"
[[ -n "$selection" ]] || exit 0

text="$(grim -g "$selection" - | tesseract stdin stdout --oem 1 --psm 6 -l "${NOTARCHY_OCR_LANGS:-${OMARCHY_OCR_LANGS:-eng}}" --dpi 300 -c preserve_interword_spaces=1 2>/dev/null)"
[[ -n "$text" ]] || exit 1
printf '%s' "$text" | wl-copy
notify-send "OCR copied to clipboard"
